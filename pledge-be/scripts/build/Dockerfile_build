# Need to package the code first `tar zcf pledge_be.tar.gz $(ls)` and move it to the same directory as Dokerfile

# Compile the go code, you can specify the golang version
FROM golang:1.23-alpine as build
COPY . /go/src/pledge_be
WORKDIR /go/src/pledge_be
RUN tar zxf pledge_be.tar.gz
RUN go env -w GOPROXY=https://goproxy.cn,direct
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /pledge_be cmd/pledge_be/main.go

# compressing binary files
#cd /
#upx -9 pledge_be


# building images with binary
FROM alpine:latest
MAINTAINER zhufuyi "g.zhufuyi@gmail.com"

# add curl, used for http service checking, can be installed without it if deployed in k8s
RUN apk add curl

COPY --from=build /pledge_be /app/pledge_be
COPY --from=build /go/src/pledge_be/configs/pledge_be.yml /app/configs/pledge_be.yml

# http port
EXPOSE 8080


WORKDIR /app

CMD ["./pledge_be", "-c", "configs/pledge_be.yml"]
# if you use the Configuration Center, pledge_be.yml is changed to the Configuration Center configuration.
#CMD ["./pledge_be", "-c", "configs/pledge_be.yml", "-enable-cc"]
